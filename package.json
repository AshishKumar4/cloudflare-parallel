{
  "name": "cloudflare-parallel",
  "version": "0.3.0",
  "description": "Composed-topology parallel computing for Cloudflare Workers — N child DOs × 4 loaders each = 4N parallel V8 isolates per request, with hierarchical tree scaling beyond.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./durable-objects": {
      "types": "./dist/durable-objects.d.ts",
      "import": "./dist/durable-objects.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "MIGRATION.md",
    "DESIGN.md",
    "docs"
  ],
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "worker-loader",
    "parallel",
    "fan-out",
    "scheduler",
    "actor",
    "vm",
    "sandbox"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishKumar4/cloudflare-parallel"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests scripts examples --max-warnings=0",
    "lint:fix": "eslint src tests scripts examples --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'scripts/**/*.ts' 'examples/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'scripts/**/*.ts' 'examples/**/*.ts'",
    "test": "bun test tests/unit",
    "test:integration": "bun run tests/integration/run.ts",
    "test:prod": "bun run tests/prod/run.ts",
    "bench": "bun run tests/bench/run.ts",
    "migrate": "bun run scripts/migrate-v02-v03.ts",
    "prepublishOnly": "bun run clean && bun run typecheck && bun run lint && bun run test && bun run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2",
    "wrangler": "^3.60.0 || ^4.0.0"
  }
}
