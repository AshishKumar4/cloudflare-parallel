{
  "name": "cloudflare-parallel",
  "version": "0.2.0",
  "description": "Parallel computing primitives for Cloudflare Workers — binding passthrough, context capture, timeouts, retries, and streaming",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cloudflare",
    "workers",
    "parallel",
    "multiprocessing",
    "service-bindings",
    "worker-loader",
    "pmap",
    "concurrency",
    "distributed",
    "serverless",
    "ai",
    "fanout"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AshishKumar4/cloudflare-parallel"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.60.0"
  }
}
